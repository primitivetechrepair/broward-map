{
  "name": "broward-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run clean:ports && concurrently npm:frontend npm:backend",
    "frontend": "vite",
    "backend": "nodemon --watch server --ext js,mjs,cjs,json server/sendOrder.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean:ports": "kill-port 5000 5173 5174",
    "dev:reset": "kill-port 5000 5173 5174 && npm run dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^8.2.0",
    "eslint": "^8.0.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.1",
    "vite": "^5.0.0"
  }
}
